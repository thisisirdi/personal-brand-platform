generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id         String   @id @default(uuid())
  title      String
  slug       String   @unique
  summary    String
  content    String
  category   String
  techStack  String[] @default([])
  status     String   @default("published")
  featured   Boolean  @default(false)
  orderIndex Int      @default(0)
  githubUrl  String?
  demoUrl    String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status, featured, orderIndex])
  @@index([category])
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
